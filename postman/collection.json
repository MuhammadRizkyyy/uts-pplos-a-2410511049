  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    console.log('User registered successfully');",
                  "    console.log('Please use Login request to get tokens');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Muhammad Rizky\",\n  \"email\": \"rizky@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"tenant\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.accessToken) {",
                  "        pm.collectionVariables.set('access_token', response.accessToken);",
                  "        pm.collectionVariables.set('refresh_token', response.refreshToken);",
                  "        console.log('✅ Tokens saved from login');",
                  "        console.log('Access Token:', response.accessToken.substring(0, 20) + '...');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rizky@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.accessToken) {",
                  "        pm.collectionVariables.set('access_token', response.accessToken);",
                  "        pm.collectionVariables.set('refresh_token', response.refreshToken);",
                  "        console.log('✅ Access token refreshed');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "GitHub OAuth - Step 1: Get Authorization URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/oauth/github",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "oauth", "github"]
            },
            "description": "⚠️ MANUAL STEP: Open this URL in browser to authorize with GitHub.\nAfter authorization, GitHub will redirect to callback URL with 'code' parameter.\nCopy the 'code' from URL and use it in Step 2."
          }
        },
        {
          "name": "GitHub OAuth - Step 2: Exchange Code for Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.accessToken) {",
                  "        pm.collectionVariables.set('access_token', response.accessToken);",
                  "        pm.collectionVariables.set('refresh_token', response.refreshToken);",
                  "        console.log('✅ GitHub OAuth successful - Tokens saved');",
                  "        console.log('User:', response.user.name, '(' + response.user.email + ')');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/oauth/github/callback?code=YOUR_GITHUB_CODE_HERE",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "oauth", "github", "callback"],
              "query": [
                { "key": "code", "value": "YOUR_GITHUB_CODE_HERE", "description": "Replace with actual code from GitHub redirect" }
              ]
            },
            "description": "Replace YOUR_GITHUB_CODE_HERE with the actual code from GitHub OAuth redirect URL"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
